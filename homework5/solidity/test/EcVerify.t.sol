pragma solidity ^0.8.13;

import {Test} from "forge-std/Test.sol";
import { EcVerify, ECPoint } from "../src/EcVerify.sol";

contract EcVerifyTest is Test {
    EcVerify public ecVerify;

    function setUp() public {
        ecVerify = new EcVerify();
    }

    function test_basic_sanity_1() public view {
        ECPoint memory A = ECPoint({ x: 9748792386036594667425720882953785528214458564285655514713105365940035440705, y: 9949157821591421077269534889111390778122805415096598016616563637825746781662});
        ECPoint memory B = ECPoint({ x: 3343918042967540208225977723522284855069684048492470305861181292984617453905, y: 20805859750762584570846042358547212541688978425085006868741717766513047414648});
        uint256 num = 2;
        uint256 den = 3;
        assertTrue(ecVerify.rationalAdd(A, B, num, den));
    }

    function test_with_wrong_den() public view {
        ECPoint memory A = ECPoint({ x: 20250284575578090205548042168212965911292575340615166602586842042427154554667, y: 6676832187069851274077512980013570006188864201352285055079314988747613461115});
        ECPoint memory B = ECPoint({ x: 989295267447878723650425477977682307739457138839837720033719555471234729306, y: 19213731004525142149874570282940582303673379962598448685972933112977385450643});
        uint256 num = 205;
        uint256 den = 421; // correct den = 3
        assertFalse(ecVerify.rationalAdd(A, B, num, den));
    }

    function test_basic_sanity_2() public view {
        ECPoint memory A = ECPoint({ x:14064970663287174031466329090495198168712191120678735678219506606241108837250, y:7852460286757109420067800883086981186857472001252044565920786778055209419845});
        ECPoint memory B = ECPoint({ x:12427278377988352714403382843209038310580325130945623684973389972081955259594, y: 8652763036771995824680333083066385076639889062136961816751957600398550113634});
        uint256 num = 205;
        uint256 den = 421;
        assertTrue(ecVerify.rationalAdd(A, B, num, den));
    }

    function test_corner_case() public {
        ECPoint memory A = ECPoint({ x: 14064970663287174031466329090495198168712191120678735678219506606241108837250, y: 7852460286757109420067800883086981186857472001252044565920786778055209419845});
        ECPoint memory B = ECPoint({ x: 12427278377988352714403382843209038310580325130945623684973389972081955259594, y: 8652763036771995824680333083066385076639889062136961816751957600398550113634});
        uint256 num = 205;
        uint256 den = 0;

        vm.expectRevert("denominator can not be 0");
        ecVerify.rationalAdd(A, B, num, den);
    }
}
