pragma solidity ^0.8.13;

import {Test} from "forge-std/Test.sol";
import { MatrixMul, ECPoint } from "../src/MatrixMul.sol";

contract MatrixMulTest is Test {
    uint256[][] matrix = new uint256[][](3);
    uint n = 3;
    MatrixMul public matrixMul = new MatrixMul();
    ECPoint[] public points;
    uint256[] public o;

    function setUp() public {
        matrix[0] = [1, 2, 3];
        matrix[1] = [4, 5, 6];
        matrix[2] = [7, 8, 9];
    }

    function test_matrix_dimensions_zero() public {
        vm.expectRevert("Invalid length for inputs");
        matrixMul.matrixmul(matrix, n, points, o);
    }

    function test_matrix_dimensions_mismatch() public {
         ECPoint[] memory s = new ECPoint[](1);
          s[0] = ECPoint({ x: 9683343654367757419827152457179063998004441246479483444486502390213749077094, y: 18501814144513014012233879037954172036524309137464453483439962024813616224475 });

          vm.expectRevert("Length of matrix don't match");
          matrixMul.matrixmul(matrix, n, s, o);
    }

    function test_basic_sanity() public {
        ECPoint[] memory s = new ECPoint[](n);
        s[0] = ECPoint({ x: 9683343654367757419827152457179063998004441246479483444486502390213749077094, y: 18501814144513014012233879037954172036524309137464453483439962024813616224475 });
        s[1] = ECPoint({ x: 7836770001293989750992810995877695111307888428499464804232182913529274105678, y: 12356906927071856727944377834063623210661560671699713358993600871535965868519 });
        s[2] = ECPoint({ x: 9763576849315605659168602819179615154793807596151458642176997310141812858493, y: 17134302643566865208166170343554240217126122780656332613767759482303610073193 });

        // uint256[] o (M*k mod curve_order)
        uint256[] memory _o = new uint256[](3);
        _o[0] = 7201218276282954932983223850063129490727098751777488068198342154823283377964;
        _o[1] = 9669383839832372422172337415686989209167782723615799180648584563467260406338;
        _o[2] = 12137549403381789911361450981310848927608466695454110293098826972111237434712;

        assertTrue(matrixMul.matrixmul(matrix, n, s, _o));
    }

    function test_basic_sanity_1() public {
        ECPoint[] memory s = new ECPoint[](n);
        s[0] = ECPoint({ x: 19423828187863605823578142171376824281585158143385795766175995291371593527636, y: 15931487849058436592073018498949515947039463071829042695605871526198411162273 });
        s[1] = ECPoint({ x: 8381523939803246701667220805378554295904456554819484372591817837759347061335, y: 8766097024135183757892218652884512944895031935165639968300163498193226168177 });
        s[2] = ECPoint({ x: 7308397463977272677858338016395468766406648902319844145408250436660647543332, y: 19815946123375396537741705852381369835396133719559681955197297643026433976913 });

        // uint256[] o (M*k mod curve_order)
        uint256[] memory _o = new uint256[](3);
        _o[0] = 17788722367605164431314523177365400229353760767922731837662683910942579006648;
        _o[1] = 19900319935672435125842768796277732449047623308926060270634656356974960889257;
        _o[2] = 123674631900430598124608669932789580193121449513354359908424616431534276249;

        assertTrue(matrixMul.matrixmul(matrix, n, s, _o));
    }

    function test_basic_sanity_mismatch() public {
        ECPoint[] memory s = new ECPoint[](n);
        s[0] = ECPoint({ x: 19423828187863605823578142171376824281585158143385795766175995291371593527636, y: 15931487849058436592073018498949515947039463071829042695605871526198411162273 });
        s[1] = ECPoint({ x: 8381523939803246701667220805378554295904456554819484372591817837759347061335, y: 8766097024135183757892218652884512944895031935165639968300163498193226168177 });
        s[2] = ECPoint({ x: 7308397463977272677858338016395468766406648902319844145408250436660647543332, y: 19815946123375396537741705852381369835396133719559681955197297643026433976913 });

        // uint256[] o (M*k mod curve_order)
        uint256[] memory _o = new uint256[](3);
        _o[0] = 17788722367605164431314523177365400229353760767922731837662683910942579006648;
        _o[1] = 19900319935672435125842768796277732449047623308926060270634656356974960889257;
        _o[2] = 12137549403381789911361450981310848927608466695454110293098826972111237434712;
        // _o[2] correct value is 123674631900430598124608669932789580193121449513354359908424616431534276249;

        assertFalse(matrixMul.matrixmul(matrix, n, s, _o));
    }
}